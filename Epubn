<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perpustakaan EPUB Digital</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.5/jszip.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"></script>
    <script src="https://unpkg.com/dexie/dist/dexie.js"></script>

    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; margin: 0; padding: 20px; }
        .container { max-width: 900px; margin: auto; }
        
        /* Library/Grid Style */
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 20px; margin-top: 20px; }
        .book-card { background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1); text-align: center; padding: 10px; position: relative; }
        .book-card img { width: 100%; height: 240px; object-fit: cover; border-radius: 5px; }
        
        /* Reader Style */
        #reader-view { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; z-index: 100; }
        #viewer { height: 85vh; width: 100%; overflow-y: auto; }
        .toolbar { padding: 15px; background: #333; color: white; display: flex; justify-content: space-between; }
        button { cursor: pointer; padding: 8px 15px; border: none; border-radius: 5px; background: #007bff; color: white; }
        button.danger { background: #dc3545; }
    </style>
</head>
<body>

<div id="library-view" class="container">
    <h1>Perpustakaan Saya</h1>
    <input type="file" id="file-input" accept=".epub">
    <div id="book-list" class="grid"></div>
</div>

<div id="reader-view">
    <div class="toolbar">
        <button onclick="closeReader()">⬅ Kembali</button>
        <div id="book-title">Membaca...</div>
        <div class="controls">
            <button id="prev-page">Sebelumnya</button>
            <button id="next-page">Selanjutnya</button>
        </div>
    </div>
    <div id="viewer"></div>
</div>

<script>
// 1. Inisialisasi Database
const db = new Dexie("MyLibrary");
db.version(1).stores({ books: "++id, title, author, data, cover" });

const fileInput = document.getElementById('file-input');
const bookList = document.getElementById('book-list');
let rendition;

// 2. Fungsi Tambah Buku
fileInput.onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const bookData = await file.arrayBuffer();
    const ebu = ePub(bookData);
    const meta = await ebu.loaded.metadata;
    let coverImg = "https://via.placeholder.com/150x200?text=No+Cover";

    try {
        const coverPath = await ebu.coverUrl();
        const res = await fetch(coverPath);
        coverImg = await res.blob();
    } catch (err) { console.log("Cover gagal dimuat"); }

    await db.books.add({
        title: meta.title,
        author: meta.author,
        data: file,
        cover: coverImg
    });
    
    renderLibrary();
};

// 3. Tampilkan Perpustakaan
async function renderLibrary() {
    bookList.innerHTML = "";
    const allBooks = await db.books.toArray();

    allBooks.forEach(book => {
        const url = book.cover instanceof Blob ? URL.createObjectURL(book.cover) : book.cover;
        const card = document.createElement('div');
        card.className = 'book-card';
        card.innerHTML = `
            <img src="${url}">
            <h4>${book.title}</h4>
            <button onclick="openBook(${book.id})">Baca</button>
            <button class="danger" onclick="deleteBook(${book.id})">Hapus</button>
        `;
        bookList.appendChild(card);
    });
}

// 4. Buka Reader
async function openBook(id) {
    const bookData = await db.books.get(id);
    document.getElementById('library-view').style.display = 'none';
    document.getElementById('reader-view').style.display = 'block';

    const reader = new FileReader();
    reader.onload = (e) => {
        const book = ePub(e.target.result);
        rendition = book.renderTo("viewer", { 
            width: "100%", 
            height: "100%", 
            flow: "scrolled", // Mode Gulir
            manager: "continuous"
        });
        rendition.display();
    };
    reader.readAsArrayBuffer(bookData.data);
}

function closeReader() {
    location.reload(); // Cara termudah untuk reset viewer
}

async function deleteBook(id) {
    await db.books.delete(id);
    renderLibrary();
}

// Jalankan saat startup
renderLibrary();
</script>

</body>
</html>
